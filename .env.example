# ============================================================
# Project ARES-Mem — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ── Required: LLM Backend ────────────────────────────────────
# OpenAI API key used by ThreatAnalysisAgent and DecisionAgent
OPENAI_API_KEY=sk-...

# Optional: Override the OpenAI base URL (e.g. for Azure / local proxy)
# OPENAI_BASE_URL=https://your-endpoint.openai.azure.com/

# ── Optional: SDK Integrations ───────────────────────────────
# OpenSandbox API key (required only if using opensandbox_service.py)
# OPENSANDBOX_API_KEY=sbx-...

# Google ADK API key (required only if using google_adk_service.py)
# GOOGLE_API_KEY=AIza...

# ── Optional: ChromaDB Remote Host ───────────────────────────
# If unset, the system uses local PersistentClient (src/chroma_data/)
# CHROMA_HOST=localhost
# CHROMA_PORT=8000
