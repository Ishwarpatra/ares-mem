# ================================================
# Project ARES-Mem — Environment Template
# Copy to `.env` and fill in your actual values.
# The system runs fully without API keys (deterministic mode).
# ================================================

# ── ChromaDB (Docker) ─────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ── Optional LLM Integrations ─────────────────────
# Only needed if using LLM-enhanced summarization mode
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1

GOOGLE_API_KEY=

# ── Optional Sandbox Execution ────────────────────
OPENSANDBOX_API_KEY=

# ── ARES Environment Mode ─────────────────────────
# Options: local | docker | test
ARES_ENV=local
